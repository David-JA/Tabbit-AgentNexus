{
  "profile": "t4_implementation_verification",
  "mode": "review_only",
  "write_enabled": false,
  "commands_enabled": false,
  "max_total_context_bytes": 1600000,
  "max_file_bytes": 200000,
  "max_file_count": 32,
  "oversized_file_behavior": "skip_with_summary",
  "binary_behavior": "skip",
  "allow_globs": [
    "readme.md",
    "AGENTS.md",
    "docs/architecture/nexus_runtime_architecture.md",
    "docs/workflows/agent_conventions.md",
    "discuss/2026-06-15_n1-foundation-relay-validation-spec.md",
    ".agent/skills/nexus-local-workspace-review/**",
    "config/**",
    "scripts/message_envelope.py",
    "scripts/relay_ledger.py",
    "scripts/relay_runner.py",
    "scripts/relay_completeness.py",
    "scripts/relay_constants.py",
    "scripts/n1_review_session.py",
    "scripts/context_packager.py",
    "scripts/policy.py",
    "tests/test_message_envelope.py",
    "tests/test_relay_ledger.py",
    "tests/test_relay_runner.py",
    "tests/test_relay_completeness.py",
    "tests/test_relay_constants.py",
    "tests/test_n1_review_session.py",
    "tests/conftest.py"
  ],
  "deny_globs": [
    ".git/**",
    "**/.git/**",
    ".env",
    ".env.*",
    "**/.env",
    "**/.env.*",
    "**/*.pem",
    "**/*.key",
    "**/*.p12",
    "**/*.pfx",
    "**/id_rsa",
    "**/id_dsa",
    "**/id_ed25519",
    "**/node_modules/**",
    "**/vendor/**",
    "**/__pycache__/**",
    "reference/**",
    "exports/**",
    "discuss/archive/**"
  ]
}
